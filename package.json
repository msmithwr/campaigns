{
  "name": "cloudwrxs-campaign-command",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:data && vite --host 127.0.0.1",
    "build": "npm run build:data && vite build",
    "build:data": "node scripts/build-campaign-data.mjs",
    "deploy:api": "bash scripts/deploy-api.sh",
    "deploy:frontend": "bash scripts/deploy-frontend.sh",
    "deploy": "npm run deploy:api && npm run deploy:frontend",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {}
}
